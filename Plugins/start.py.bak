from pyrogram import Client, filters
from utils.helpers import get_system_stats
from database.db import db

@Client.on_message(filters.command(["start", "help"]) & filters.private)
async def start_cmd(client, message):
    if await db.is_banned(message.from_user.id):
        return await message.reply_text("🚫 You are banned from using this bot.")
        
    text = (
        f"👋 **Hello {message.from_user.first_name}!**\n\n"
        f"I am an advanced ID Bot. Send `/id` or reply to a message.\n\n"
        f"🔹 `/id` - Get Chat/User/Channel ID & Premium info.\n"
        f"🔹 `/stickerid` - Reply to a sticker to get its ID.\n"
        f"🔹 `/alive` - Check if I am online & system stats."
    )
    await message.reply_text(text, quote=True)

@Client.on_message(filters.command("alive"))
async def alive_cmd(client, message):
    stats = get_system_stats()
    await message.reply_text(f"🟢 **Bot is Live & Online!**\n\n{stats}", quote=True)